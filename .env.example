# =============================================================================
# NutriSnap – Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
#
#   cp .env.example .env
#
# =============================================================================

# ----------------------------
# FLASK
# ----------------------------

# A long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here

# Environment: development | production | testing
FLASK_ENV=development

# Set to 1 to enable Flask debug mode (never use in production)
FLASK_DEBUG=1

# ----------------------------
# DATABASE (Supabase PostgreSQL)
# ----------------------------

# ── Supabase (Cloud — production & development) ──────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → URI tab
# It looks like: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres
#
# IMPORTANT: Replace [YOUR-PASSWORD] with your actual Supabase DB password.
# IMPORTANT: Keep this value secret. Never commit .env to version control.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# ── SQLite (local fallback — only if you have no internet) ───────────────────
# DATABASE_URL=sqlite:///nutrisnap_dev.db

# ----------------------------
# ML MODEL
# ----------------------------

# Path to the trained PyTorch model weights file (relative to project root)
MODEL_PATH=ml/models/food101_v1.pt

# URL to download the model from if the file is missing.
# Upload your trained .pt file to a GitHub Release, then paste the download URL here.
# Example: https://github.com/YOUR_USERNAME/NutriSnap/releases/download/v1.0/food101_v1.pt
MODEL_DOWNLOAD_URL=

# Number of top predictions to return
TOP_K_PREDICTIONS=3

# ----------------------------
# FILE UPLOAD
# ----------------------------

# Maximum allowed upload size in bytes (default: 16 MB)
MAX_CONTENT_LENGTH=16777216

# Allowed image extensions (comma-separated)
ALLOWED_EXTENSIONS=png,jpg,jpeg,webp

# Directory where uploaded images are temporarily stored
UPLOAD_FOLDER=backend/uploads

# ----------------------------
# SECURITY
# ----------------------------

# Bcrypt password hashing rounds (higher = slower = more secure)
# Recommended: 12 for production, 4 for testing
BCRYPT_LOG_ROUNDS=12

# ----------------------------
# LOGGING
# ----------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# Log file path (relative to project root)
LOG_FILE=logs/nutrisnap.log
