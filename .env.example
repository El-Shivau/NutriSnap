# =============================================================================
# NutriSnap – Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
#
#   cp .env.example .env
#
# =============================================================================

# ----------------------------
# FLASK
# ----------------------------

# A long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-secret-key-here

# Environment: development | production | testing
FLASK_ENV=development

# Set to 1 to enable Flask debug mode (never use in production)
FLASK_DEBUG=1

# ----------------------------
# DATABASE
# ----------------------------

# SQLite (development default — no setup needed)
# DATABASE_URL=sqlite:///nutrisnap.db
#
# PostgreSQL (production)
# DATABASE_URL=postgresql://username:password@localhost:5432/nutrisnap_db
DATABASE_URL=sqlite:///nutrisnap.db

# ----------------------------
# ML MODEL
# ----------------------------

# Path to the trained Keras model file (relative to project root)
# Example: ml/models/food101_v1.keras
MODEL_PATH=ml/models/food101_v1.keras

# Number of top predictions to return
TOP_K_PREDICTIONS=3

# ----------------------------
# FILE UPLOAD
# ----------------------------

# Maximum allowed upload size in bytes (default: 16 MB)
MAX_CONTENT_LENGTH=16777216

# Allowed image extensions (comma-separated)
ALLOWED_EXTENSIONS=png,jpg,jpeg,webp

# Directory where uploaded images are temporarily stored
UPLOAD_FOLDER=backend/uploads

# ----------------------------
# SECURITY
# ----------------------------

# Bcrypt password hashing rounds (higher = slower = more secure)
# Recommended: 12 for production, 4 for testing
BCRYPT_LOG_ROUNDS=12

# ----------------------------
# LOGGING
# ----------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# Log file path (relative to project root)
LOG_FILE=logs/nutrisnap.log
