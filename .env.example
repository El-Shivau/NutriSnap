# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-in-production

# Database (use SQLite for local, or PostgreSQL URI for cloud)
# SQLite: sqlite:///nutrisnap.db
# PostgreSQL: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///nutrisnap.db

# APIs
USDA_API_KEY=DEMO_KEY
HF_API_TOKEN=hf_your_real_token_here
BITEAI_API_URL=https://api.biteai.example/v1/food/recognize
BITEAI_API_KEY=your_biteai_api_key
FOOD_RECOGNITION_PROVIDER=biteai

# Server
WORKERS=4
